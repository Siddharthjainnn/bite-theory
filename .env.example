# ── Backend API (points at the NestJS server) ──
# Local dev: http://localhost:3001/api
# Production (Vercel env var): https://YOUR-BACKEND-HOST/api
NEXT_PUBLIC_API_BASE=http://localhost:3001/api

# ── NextAuth ──
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_output_of__openssl_rand_-base64_32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Postgres (used directly by NextAuth to read/write users) ──
DATABASE_URL=postgres://postgres:password@localhost:5432/bite_theory
# Set PGSSL=off for a local DB without SSL
PGSSL=off

# ── Google Maps (MapPicker) ──
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Razorpay public key id is served by the backend's create-payment response,
# so it is NOT required here. Never put RAZORPAY_KEY_SECRET in this file.
